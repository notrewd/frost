{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the default windows",
  "windows": [
    "welcome",
    "editor",
    "settings",
    "export",
    "edges-outliner",
    "history",
    "generate"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-toggle-maximize",
    "core:window:allow-minimize",
    "core:window:allow-destroy",
    "os:default",
    "dialog:default"
  ]
}